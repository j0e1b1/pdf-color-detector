{
  "manifest_version": 3,
  "name": "PDF Color Detector",
  "version": "1.0",
  "description": "Detects which pages in a PDF contain color.",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Scan PDF for Color"
  }
}